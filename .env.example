# Copiez ce fichier en .env et remplissez les valeurs

# Supabase
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_ici

# Stripe (clé publique — la clé secrète va dans Supabase Edge Functions)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_votre_cle

# PayPal (client ID sandbox ou live)
VITE_PAYPAL_CLIENT_ID=votre_client_id_paypal

# URL du site en production (emails + redirects auth)
VITE_SITE_URL=https://ykonline.shop

# ── Local dev only (paiement Stripe sans déployer les Edge Functions) ──
# STRIPE_SECRET_KEY=sk_test_...
# SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# ── Secrets Supabase Edge Functions (Dashboard → Edge Functions → Secrets) ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...
# ADMIN_EMAIL=contact@ykonline.shop
# ADMIN_WHATSAPP=13012669830
# WHATSAPP_CLOUD_TOKEN=...        (Meta WhatsApp Business API)
# WHATSAPP_PHONE_NUMBER_ID=...
